---
import HeroCanvas from './HeroCanvas.jsx';
---
<section id="hero" class="hero light-theme">
  <div class="hero-ambience">
    <div class="light-blob blob-blue"></div>
    <div class="light-blob blob-warm"></div>
    <div class="blueprint-grid"></div>
  </div>

  <div class="container hero-inner">
    <div class="hero-left">
      <div class="hero-badge reveal">
        <span class="status-dot"></span>
        <span class="badge-text">SaaS-Driven Consulting Firm</span>
      </div>
      
      <h1 class="hero-title reveal stagger-1">
        Transforming <br />
        Businesses into <br />
        <span class="text-navy">Scalable Systems</span>
      </h1>
      
      <p class="hero-sub reveal stagger-2">
        VAC Global Solutions bridges the gap between technology and legacy 
        operations — replacing fragmented workflows with unified, intelligent 
        systems built for sustainable growth.
      </p>

      <div class="hero-actions reveal stagger-3">
        <a href="#contact" class="btn-enterprise">
          <span>Book a Free Demo</span>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14m-7-7l7 7-7 7"/></svg>
        </a>
        <a href="#about" class="btn-text-link">Learn More</a>
      </div>

      <div class="hero-stats-glass reveal stagger-4">
        <div class="stat-node">
          <span class="value">50+</span>
          <span class="label">Clients Served</span>
        </div>
        <div class="v-divider"></div>
        <div class="stat-node">
          <span class="value">10+</span>
          <span class="label">Industries</span>
        </div>
        <div class="v-divider"></div>
        <div class="stat-node">
          <span class="value">5+</span>
          <span class="label">SaaS Products</span>
        </div>
      </div>
    </div>

    <div class="hero-right reveal-right stagger-1">
      <div class="display-container">
         <HeroCanvas client:load />
      </div>
    </div>
  </div>
</section>

<style>
.hero.light-theme {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  /* Premium light background palette */
  background-color: #fcfcfd; 
  overflow: hidden;
  padding-top: 100px;
}

/* 1. Luminous Background */
.hero-ambience {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.light-blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(140px);
  opacity: 0.4;
}

/* Soft Enterprise Blue */
.blob-blue {
  width: 900px; height: 900px;
  background: radial-gradient(circle, #e0eaff, transparent);
  top: -300px; right: -200px;
}

/* Subtle secondary blue accent */
.blob-warm {
  width: 700px; height: 700px;
  background: radial-gradient(circle, #f0f7ff, transparent);
  bottom: -150px; left: -100px;
}

.blueprint-grid {
  position: absolute;
  inset: 0;
  background-image: radial-gradient(#e2e8f0 1.2px, transparent 0);
  background-size: 44px 44px;
  opacity: 0.5;
  mask-image: radial-gradient(circle at 50% 50%, black, transparent 85%);
}

/* 2. Content Styling */
.hero-inner {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 5rem;
  align-items: center;
  z-index: 5;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 8px 16px;
  background: #fff;
  border: 1px solid #e2e8f0;
  border-radius: 100px;
  box-shadow: 0 2px 10px rgba(0, 45, 98, 0.04);
  margin-bottom: 2rem;
}

.status-dot {
  width: 8px; height: 8px;
  background: var(--accent-blue);
  border-radius: 50%;
  box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
}

.badge-text {
  font-size: 0.75rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: #002D62;
}

.hero-title {
  font-size: clamp(2.5rem, 5vw, 4rem);
  font-weight: 900;
  line-height: 1.05;
  color: #0f172a;
  letter-spacing: -0.04em;
  margin-bottom: 1.5rem;
}

.text-navy {
  color: #002D62; /* Solid professional primary */
}

.hero-sub {
  font-size: 1.15rem;
  color: #475569;
  line-height: 1.7;
  max-width: 520px;
  margin-bottom: 3rem;
}

/* 3. Action Buttons */
.hero-actions {
  display: flex;
  align-items: center;
  gap: 2rem;
  margin-bottom: 4rem;
}

.btn-enterprise {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  background: #002D62;
  color: #fff;
  padding: 18px 34px;
  border-radius: 14px;
  font-weight: 800;
  text-decoration: none;
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

.btn-enterprise:hover {
  background: #001D3D;
  transform: translateY(-3px);
  box-shadow: 0 15px 30px rgba(0, 45, 98, 0.15);
}

.btn-text-link {
  color: #0f172a;
  font-weight: 700;
  text-decoration: none;
  border-bottom: 2px solid #e2e8f0;
  padding-bottom: 2px;
  transition: border-color 0.3s;
}

.btn-text-link:hover { border-color: #002D62; }

/* 4. Refined Stats */
.hero-stats-glass {
  display: flex;
  gap: 2.5rem;
  padding: 24px 32px;
  background: #ffffff;
  border: 1px solid #e2e8f0;
  border-radius: 24px;
  width: fit-content;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.03);
}

.stat-node .value {
  display: block;
  font-size: 2rem;
  font-weight: 800;
  color: #002D62;
  letter-spacing: -0.02em;
}

.stat-node .label {
  font-size: 0.75rem;
  color: #64748b;
  font-weight: 700;
  text-transform: uppercase;
}

.v-divider {
  width: 1px; height: 40px;
  background: #f1f5f9;
  align-self: center;
}

/* 5. Right Display (Canvas) */
.display-container {
  padding: 10px;
  background: #ffffff;
  border: 1px solid #e2e8f0;
  border-radius: 40px;
  box-shadow: 0 40px 80px -20px rgba(0, 45, 98, 0.12);
}

@media (max-width: 1024px) {
  .hero-inner { grid-template-columns: 1fr; text-align: center; padding-top: 40px; }
  .hero-sub, .hero-stats-glass { margin-left: auto; margin-right: auto; }
  .hero-actions { justify-content: center; }
}

@media (max-width: 768px) {
  .hero.light-theme { padding-top: 80px; }
  .hero-title { font-size: 2.8rem; }
  .hero-sub { font-size: 1rem; margin-bottom: 2rem; }
  .hero-actions { flex-direction: column; gap: 1rem; align-items: stretch; max-width: 320px; margin: 0 auto 3rem; }
  .hero-stats-glass { 
    flex-wrap: wrap; 
    justify-content: center; 
    gap: 1.5rem 2rem;
    padding: 20px;
  }
  .stat-node .value { font-size: 1.5rem; }
  .v-divider { display: none; }
  .display-container {
    border-radius: 24px;
    padding: 10px;
    margin: 0 -15px; /* Slight bleed on very small screens */
  }
}

@media (max-width: 480px) {
  .hero-title { font-size: 2.2rem; }
}
</style>