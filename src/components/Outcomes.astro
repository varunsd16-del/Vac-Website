---
---
<section class="section outcomes-wrapper">
  <div class="container">
    <div class="outcomes-layout">
      
      <div class="outcomes-content reveal">
        <header class="content-header">
          <span class="eyebrow-tag">Operational ROI</span>
          <h2 class="display-h2">Real Results. <br/><span class="text-accent">Measurable Impact.</span></h2>
          <p class="section-description">
            We don't just implement software; we re-engineer the way your business breathes. Our clients experience structural shifts in how data drives daily decisions.
          </p>
        </header>

        <ul class="benefit-stack">
          {[
            "Replaced Excel-based ops with automated ERP workflows",
            "360° visibility across inventory and finance in real-time",
            "Integrated sales & fulfilment for faster cash cycles",
            "Live dashboards reducing reporting time to minutes"
          ].map((text) => (
            <li class="benefit-item">
              <div class="item-dot"></div>
              <span>{text}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="outcomes-stats">
        {[
          { val: '40%', label: 'Efficiency Improvement', desc: 'Manual overhead reduction', color: '#002D62' },
          { val: '25%', label: 'Cost Reduction', desc: 'Average operational savings', color: '#3b82f6' },
          { val: '3×', label: 'Visibility Gain', desc: 'Live cross-departmental data', color: '#1E4FA0' }
        ].map((stat, i) => (
          <div class={`metric-card reveal stagger-${i+1}`} style={`--accent: ${stat.color}`}>
            <div class="metric-visual">
              <span class="metric-value">{stat.val}</span>
              <div class="metric-bar"></div>
            </div>
            <div class="metric-info">
              <h4 class="metric-label">{stat.label}</h4>
              <p class="metric-desc">{stat.desc}</p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

<style>
.outcomes-wrapper {
  background-color: #ffffff;
  padding: 100px 0;
  position: relative;
  overflow: hidden;
}

/* Decorative background element */
.outcomes-wrapper::after {
  content: '';
  position: absolute;
  bottom: 0; right: 0;
  width: 40%; height: 60%;
  background: radial-gradient(circle at bottom right, rgba(0, 45, 98, 0.03), transparent 70%);
  pointer-events: none;
}

.outcomes-layout {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 6rem;
  align-items: center;
}

/* Left Content Styles */
.eyebrow-tag {
  color: #002D62;
  font-weight: 700;
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  display: block;
  margin-bottom: 1.25rem;
}

.display-h2 {
  font-size: clamp(2.2rem, 4vw, 3rem);
  font-weight: 800;
  line-height: 1.1;
  color: #0f172a;
  letter-spacing: -0.02em;
}

.text-accent { color: #64748b; font-weight: 400; }

.section-description {
  margin-top: 1.5rem;
  font-size: 1.1rem;
  color: #64748b;
  line-height: 1.7;
  max-width: 520px;
}

.benefit-stack {
  list-style: none;
  padding: 0;
  margin-top: 3rem;
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.benefit-item {
  display: flex;
  align-items: center;
  gap: 1rem;
  font-size: 1rem;
  color: #334155;
  font-weight: 500;
}

.item-dot {
  width: 8px; height: 8px;
  background: #002D62;
  border-radius: 50%;
  flex-shrink: 0;
  box-shadow: 0 0 0 4px rgba(0, 45, 98, 0.1);
}

/* Right Stat Card Styles */
.outcomes-stats {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.metric-card {
  background: #f8fafc;
  border: 1px solid #f1f5f9;
  border-radius: 24px;
  padding: 2.5rem;
  display: flex;
  align-items: center;
  gap: 2.5rem;
  transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}

.metric-card:hover {
  background: #ffffff;
  border-color: #e2e8f0;
  transform: translateX(12px);
  box-shadow: 0 20px 40px -15px rgba(0, 45, 98, 0.1);
}

.metric-visual {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  min-width: 80px;
}

.metric-value {
  font-size: 3rem;
  font-weight: 800;
  color: var(--accent);
  letter-spacing: -0.04em;
  line-height: 1;
}

.metric-bar {
  width: 40px; height: 4px;
  background: var(--accent);
  border-radius: 2px;
  opacity: 0.3;
}

.metric-label {
  font-size: 1.15rem;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 0.25rem;
}

.metric-desc {
  font-size: 0.9rem;
  color: #64748b;
  font-weight: 500;
}

@media (max-width: 1024px) {
  .outcomes-layout { grid-template-columns: 1fr; gap: 4rem; }
  .metric-card { padding: 2rem; }
}

@media (max-width: 640px) {
  .metric-card { flex-direction: column; align-items: flex-start; gap: 1rem; }
  .metric-visual { align-items: flex-start; }
}
</style>