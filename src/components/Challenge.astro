---
const challenges = [
  {
    num: '01',
    title: 'Manual & Excel Operations',
    desc: 'Critical business data lives in spreadsheets and email threads — no single source of truth.',
    color: '#8B5CF6', // Electric Purple
    gradient: 'from-purple-500/20 to-transparent'
  },
  {
    num: '02',
    title: 'Zero Operational Visibility',
    desc: 'Decisions made without real-time data. Inventory and cash flow remain unknown.',
    color: '#06B6D4', // Cyan
    gradient: 'from-cyan-500/20 to-transparent'
  },
  {
    num: '03',
    title: 'No Scalable Systems',
    desc: 'What works for 10 people breaks at 50. Growth creates chaos instead of profit.',
    color: '#F97316', // Orange/Amber
    gradient: 'from-orange-500/20 to-transparent'
  },
];
---

<section class="challenge-wrapper">
  <div class="container">
    <div class="header-group reveal">
      <span class="badge">The Architecture Gap</span>
      <h2 class="title-display">Why Businesses <span class="text-gradient">Struggle to Scale</span></h2>
      <p class="subtitle">
        Scaling requires infrastructure, not just effort. We solve the structural bottlenecks that keep founders stuck in the weeds.
      </p>
    </div>

    <div class="bento-grid">
      {challenges.map((item, i) => (
        <div class={`glass-card reveal stagger-${i + 1}`} style={`--accent: ${item.color}`}>
          <div class="card-glow"></div>
          <div class="card-content">
            <div class="num-badge">{item.num}</div>
            <h3 class="card-title">{item.title}</h3>
            <p class="card-text">{item.desc}</p>
          </div>
          <div class="card-footer">
            <div class="status-indicator"></div>
            <span>Systemic Bottleneck</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
<style>
:root {
  --glass-bg: rgba(10, 10, 12, 0.7);
  --glass-border: rgba(255, 255, 255, 0.08);
  --text-dim: rgba(255, 255, 255, 0.5);
  --font-display: 'Inter', system-ui, sans-serif; /* Use a premium sans-serif */
}

.challenge-wrapper {
  background: #050505;
  padding: 100px 0;
  position: relative;
  overflow: hidden;
}

/* Subtle background texture */
.challenge-wrapper::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle at 2px 2px, rgba(255,255,255,0.03) 1px, transparent 0);
  background-size: 40px 40px;
}

.header-group {
  text-align: center;
  max-width: 700px;
  margin: 0 auto 80px;
}

.badge {
  display: inline-block;
  padding: 6px 14px;
  background: rgba(255,255,255,0.05);
  border: 1px solid var(--glass-border);
  border-radius: 100px;
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--accent, var(--primary));
  margin-bottom: 1.5rem;
}

.title-display {
  font-size: clamp(2.5rem, 5vw, 3.5rem);
  font-weight: 800;
  line-height: 1.1;
  color: #fff;
  letter-spacing: -0.02em;
}

.subtitle {
  font-size: 1.1rem;
  color: rgba(255,255,255,0.85);
  line-height: 1.6;
}

.text-gradient {
  background: linear-gradient(to right, #fff, rgba(255,255,255,0.4));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

/* Bento Grid Design */
.bento-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
}

.glass-card {
  position: relative;
  background: var(--glass-bg);
  backdrop-filter: blur(12px);
  border: 1px solid var(--glass-border);
  border-radius: 24px;
  padding: 3rem 2.5rem;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 320px;
  transition: all 0.5s cubic-bezier(0.2, 1, 0.3, 1);
}

/* The "Senior" Touch: Spot Lighting */
.card-glow {
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
  background: radial-gradient(800px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), 
              rgba(255,255,255,0.06), transparent 40%);
  opacity: 0;
  transition: opacity 0.5s;
  pointer-events: none;
}

.glass-card:hover {
  transform: translateY(-10px) scale(1.02);
  border-color: rgba(255,255,255,0.2);
  box-shadow: 0 20px 40px rgba(0,0,0,0.4);
}

.glass-card:hover .card-glow {
  opacity: 1;
}

.num-badge {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 100px;
  background: rgba(255,255,255,0.03);
  border: 1px solid var(--glass-border);
  font-weight: 700;
  color: var(--accent);
  margin-bottom: 2rem;
}

.card-title {
  font-size: 1.5rem;
  font-weight: 600;
  color: #fff;
  margin-bottom: 1rem;
}

.card-text {
  font-size: 1rem;
  color: rgba(255,255,255,0.7);
  line-height: 1.6;
}

.card-footer {
  margin-top: 2rem;
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 0.8rem;
  color: var(--text-dim);
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.status-indicator {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--accent);
  box-shadow: 0 0 10px var(--accent);
}

@media (max-width: 1024px) {
  .bento-grid { grid-template-columns: 1fr; }
}
</style>